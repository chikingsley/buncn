{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "extends": ["ultracite/biome/core", "ultracite/biome/react"],
  "css": {
    "parser": {
      "cssModules": true,
      "tailwindDirectives": true
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "!**/node_modules",
      "!**/dist",
      "!**/build",
      "!**/public",
      "!**/.turbo",
      "!**/.next",
      "!**/example"
    ]
  },
  "javascript": {
    "globals": ["Bun"]
  }
}
