{
  "name": "buncn",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/server/index.ts",
    "start": "NODE_ENV=production ./dist/buncn",
    "build": "bun build src/server/index.ts --compile --minify --outfile dist/buncn",
    "typecheck": "tsc --noEmit",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "lint": "bun run check",
    "lint:fix": "bun run fix",
    "test": "bun test",
    "clean": "rimraf --glob **/node_modules **/dist **/.tsbuildinfo",
    "db:migrate": "bun src/db/migrate.ts",
    "db:seed": "bun src/db/seed.ts",
    "db:setup": "bun run db:migrate && bun run db:seed",
    "db:reset": "rimraf data && bun run db:setup",
    "shadcn": "bunx shadcn@latest",
    "build:registry": "shadcn build"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/query-db-collection": "^1.0.30",
    "@tanstack/react-db": "^0.1.77",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.22",
    "@vidstack/react": "^1.12.13",
    "bun-plugin-tailwind": "^0.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "export-to-csv": "^1.4.0",
    "geist": "^1.7.0",
    "hls.js": "^1.6.15",
    "lucide-react": "^0.577.0",
    "motion": "^12.36.0",
    "nanoid": "^5.1.6",
    "next-themes": "^0.4.6",
    "nuqs": "2.8.9",
    "react": "19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.4",
    "react-hook-form": "7.71.2",
    "react-icons": "^5.6.0",
    "react-resizable-panels": "^4.7.2",
    "react-router-dom": "^7.13.1",
    "shadcn": "4.0.6",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "vaul-base": "^1.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@faker-js/faker": "^10.3.0",
    "@happy-dom/global-registrator": "^20.8.4",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/bun": "^1.3.10",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.8",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "ultracite": "7.3.0"
  },
  "ct3aMetadata": {
    "initVersion": "7.23.1"
  },
  "packageManager": "bun@1.3.10"
}
