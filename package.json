{
  "name": "buncn",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/server/index.ts",
    "start": "NODE_ENV=production bun src/server/index.ts",
    "build": "bun build src/server/index.ts --outdir dist --target bun --minify --sourcemap",
    "typecheck": "tsc --noEmit",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "test": "bun test",
    "clean": "rimraf --glob **/node_modules **/dist bun.lock **/.tsbuildinfo",
    "db:start": "docker compose up -d",
    "db:stop": "docker compose down",
    "db:migrate": "bun src/db/migrate.ts",
    "db:seed": "bun src/db/seed.ts",
    "db:setup": "bun run db:migrate && bun run db:seed",
    "db:reset": "bun run db:stop && rimraf docker-data && bun run db:start && sleep 10 && bun run db:setup",
    "shadcn": "bunx shadcn@latest",
    "build:registry": "shadcn build"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/query-db-collection": "^1.0.23",
    "@tanstack/react-db": "^0.1.70",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.18",
    "@vidstack/react": "^1.12.13",
    "bun-plugin-tailwind": "^0.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "export-to-csv": "^1.4.0",
    "geist": "^1.7.0",
    "hls.js": "^1.6.15",
    "lucide-react": "^0.564.0",
    "motion": "^12.34.0",
    "nanoid": "^5.1.6",
    "next-themes": "^0.4.6",
    "nuqs": "2.8.8",
    "postgres": "^3.4.8",
    "react": "19.2.3",
    "react-day-picker": "^9.13.2",
    "react-dom": "19.2.3",
    "react-hook-form": "7.70.0",
    "react-icons": "^5.5.0",
    "react-resizable-panels": "^4.6.4",
    "react-router-dom": "^7.1.5",
    "shadcn": "3.6.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "vaul-base": "^1.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.13",
    "@faker-js/faker": "^10.3.0",
    "@happy-dom/global-registrator": "^20.6.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/bun": "^1.3.9",
    "@types/node": "25.0.8",
    "@types/react": "19.2.8",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^27.4.0",
    "postcss": "^8.5.6",
    "rimraf": "^6.1.2",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "ultracite": "7.1.5"
  },
  "ct3aMetadata": {
    "initVersion": "7.23.1"
  },
  "packageManager": "bun@1.2.14"
}
